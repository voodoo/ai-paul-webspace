---
// Component script (runs on server)
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Paul Vudmaska</title>
    <style>
      :root {
        --bg-color: #667eea;
        --bg-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --text-color: white;
        --button-bg: rgba(255, 255, 255, 0.2);
        --button-border: rgba(255, 255, 255, 0.3);
        --button-hover: rgba(255, 255, 255, 0.3);
      }

      [data-theme="dark"] {
        --bg-color: #0f1419;
        --bg-gradient: linear-gradient(135deg, #0f1419 0%, #1a2332 100%);
        --text-color: #f5f5f0;
        --button-bg: rgba(212, 175, 55, 0.2);
        --button-border: rgba(212, 175, 55, 0.4);
        --button-hover: rgba(212, 175, 55, 0.3);
      }

      [data-theme="light"] {
        --bg-color: #f8f6f0;
        --bg-gradient: linear-gradient(135deg, #f8f6f0 0%, #f0ede5 100%);
        --text-color: #2c2c2c;
        --button-bg: rgba(44, 44, 44, 0.1);
        --button-border: rgba(44, 44, 44, 0.2);
        --button-hover: rgba(44, 44, 44, 0.2);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: var(--text-color);
        transition: all 0.3s ease;
      }

      .theme-toggle {
        position: fixed;
        top: 2rem;
        right: 2rem;
        background: var(--button-bg);
        border: 2px solid var(--button-border);
        border-radius: 50px;
        padding: 0.5rem 1rem;
        color: var(--text-color);
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        z-index: 100;
      }

      .theme-toggle:hover {
        background: var(--button-hover);
        transform: translateY(-2px);
      }

      .hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-gradient);
        text-align: center;
        color: var(--text-color);
      }

      .hero-content {
        max-width: 600px;
        padding: 2rem;
      }

      .name-box {
        background: linear-gradient(135deg, #d4af37, #ffd700);
        border: 3px solid #d4af37;
        border-radius: 25px;
        padding: 1.5rem 2.5rem;
        margin: 1rem 0;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        transform: translateY(0);
        transition: all 0.3s ease;
        display: inline-block;
        position: relative;
      }

      .name-box-cta {
        position: absolute;
        bottom: 1rem;
        right: 1.5rem;
        padding: 0.5rem 1rem;
        background: rgba(15, 20, 25, 0.8);
        color: white;
        text-decoration: none;
        border-radius: 20px;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .name-box-cta:hover {
        background: rgba(15, 20, 25, 0.9);
        transform: translateY(-2px);
      }

      [data-theme="light"] .name-box-cta {
        background: rgba(248, 246, 240, 0.9);
        color: #2c2c2c;
        border-color: rgba(44, 44, 44, 0.2);
      }

      [data-theme="light"] .name-box-cta:hover {
        background: rgba(248, 246, 240, 1);
      }

      .name-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
        background: linear-gradient(135deg, #ffd700, #ffed4e);
      }

      [data-theme="light"] .name-box {
        background: linear-gradient(135deg, #2c2c2c, #404040);
        border-color: #2c2c2c;
        color: #f8f6f0;
      }

      [data-theme="light"] .name-box:hover {
        background: linear-gradient(135deg, #404040, #555555);
      }

      h1 {
        font-size: 3rem;
        margin: 0;
        font-weight: 300;
        color: #0f1419;
      }

      [data-theme="light"] h1 {
        color: #f8f6f0;
      }

      .subtitle {
        font-size: 1.2rem;
        margin-bottom: 1rem;
        opacity: 0.9;
      }

      .bio {
        font-size: 1.1rem;
        margin-bottom: 2rem;
        opacity: 0.8;
        font-style: italic;
        font-weight: 300;
      }

      .toolbar {
        position: fixed;
        bottom: 2rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        gap: 1rem;
        background: var(--button-bg);
        border: 2px solid var(--button-border);
        border-radius: 50px;
        padding: 0.75rem 1.5rem;
        backdrop-filter: blur(10px);
        z-index: 100;
      }

      .toolbar-button {
        display: inline-block;
        padding: 0.5rem 1rem;
        background: transparent;
        color: var(--text-color);
        text-decoration: none;
        border-radius: 25px;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        border: 1px solid transparent;
      }

      .toolbar-button:hover {
        background: var(--button-hover);
        transform: translateY(-2px);
        border-color: var(--button-border);
      }

      @media (max-width: 768px) {
        h1 {
          font-size: 2rem;
        }

        .hero-content {
          padding: 1rem;
        }

        .theme-toggle {
          top: 1rem;
          right: 1rem;
          padding: 0.4rem 0.8rem;
          font-size: 0.8rem;
        }

        .name-box-cta {
          position: static;
          display: block;
          margin-top: 1rem;
          text-align: center;
        }

        .toolbar {
          bottom: 1rem;
          padding: 0.5rem 1rem;
        }

        .toolbar-button {
          padding: 0.4rem 0.8rem;
          font-size: 0.8rem;
        }
      }
    </style>
  </head>
  <body>
    <button class="theme-toggle" id="themeToggle">🌙 Dark</button>
    
    <section class="hero">
      <div class="hero-content">
        <div class="name-box">
          <h1>Paul Vudmaska</h1>
          <a href="https://cal.com/paul-vudmaska/15min" class="name-box-cta">Book Call</a>
        </div>
        <p class="subtitle">Simple minded to full stack developer • Rails • Astro</p>
        <p class="bio">Question Everything</p>
      </div>
    </section>

    <div class="toolbar">
      <a href="https://github.com/voodoo" class="toolbar-button">GitHub</a>
      <a href="https://cal.com/paul-vudmaska/15min" class="toolbar-button">Book a Call</a>
    </div>

    <script>
      const themeToggle = document.getElementById('themeToggle');
      const body = document.body;
      
      // Load saved theme or default to system preference
      const savedTheme = localStorage.getItem('theme') || 
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      
      body.setAttribute('data-theme', savedTheme);
      updateToggleText(savedTheme);
      
      themeToggle.addEventListener('click', () => {
        const currentTheme = body.getAttribute('data-theme');
        const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        body.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updateToggleText(newTheme);
      });
      
      function updateToggleText(theme) {
        themeToggle.textContent = theme === 'dark' ? '☀️ Light' : '🌙 Dark';
      }
    </script>
  </body>
</html>