---
// Paul's Personal Site
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Paul Vudmaska - Book a call" />
    <title>Paul Vudmaska</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="toolbar">
      <a href="https://github.com/voodoo" class="github-link" aria-label="GitHub Profile">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <div class="toolbar-right">
        <a href="https://cal.com/paul-vudmaska/15min" class="cta cta-small">Book a Call</a>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
          <span class="sun">☀️</span>
          <span class="moon">🌙</span>
        </button>
      </div>
    </nav>
    
    <main>
      <div class="name-box">
        <h1>Paul Vudmaska</h1>
        <p class="tagline">Available for hire</p>
        <p class="tagline">Rails · Astro · 17+ years shipping code</p>
        <p class="bio">"Question Everything"</p>
        <a href="https://cal.com/paul-vudmaska/15min" class="cta cta-box">Book a Call</a>
      </div>
    </main>

    <style>
      :root {
        --bg: #f5f5f0;
        --text: #2d2d2d;
        --accent: #4a5568;
        --button-bg: #2d2d2d;
        --button-text: #f5f5f0;
      }

      [data-theme="dark"] {
        --bg: #0a1628;
        --text: #f5f5f0;
        --accent: #d4af37;
        --button-bg: #d4af37;
        --button-text: #0a1628;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      body {
        background-color: var(--bg);
        color: var(--text);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.3s, color 0.3s;
      }

      main {
        text-align: center;
        padding: 2rem;
      }

      .name-box {
        background: linear-gradient(135deg, rgba(212, 175, 55, 0.15), rgba(212, 175, 55, 0.05));
        border: 2px solid var(--accent);
        border-radius: 24px;
        padding: 2.5rem 3rem;
        margin-bottom: 2rem;
        box-shadow: 0 8px 32px rgba(212, 175, 55, 0.2);
      }

      [data-theme="light"] .name-box,
      :root:not([data-theme="dark"]) .name-box {
        background: linear-gradient(135deg, rgba(45, 45, 45, 0.08), rgba(45, 45, 45, 0.02));
        border-color: var(--accent);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      }

      h1 {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 700;
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
        background: linear-gradient(135deg, var(--text), var(--accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .tagline {
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        color: var(--accent);
        margin-bottom: 0.5rem;
        font-weight: 400;
      }

      .bio {
        font-size: clamp(1rem, 2vw, 1.1rem);
        color: var(--text);
        opacity: 0.8;
        font-style: italic;
        margin-top: 1rem;
      }

      .toolbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        background: var(--bg);
        z-index: 100;
      }

      .toolbar-right {
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .github-link {
        color: var(--text);
        transition: color 0.2s;
      }

      .github-link:hover {
        color: var(--accent);
      }

      .cta {
        display: inline-block;
        padding: 1rem 2.5rem;
        font-size: 1.25rem;
        font-weight: 600;
        text-decoration: none;
        background-color: var(--button-bg);
        color: var(--button-text);
        border-radius: 8px;
        transition: transform 0.2s, box-shadow 0.2s;
      }

      .cta-small {
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
      }

      .cta-box {
        margin-top: 1.5rem;
        margin-left: auto;
        display: block;
        width: fit-content;
      }

      .cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
      }

      [data-theme="dark"] .cta:hover {
        box-shadow: 0 4px 20px rgba(212, 175, 55, 0.3);
      }

      .theme-toggle {
        background: none;
        border: 2px solid var(--accent);
        border-radius: 50%;
        width: 48px;
        height: 48px;
        cursor: pointer;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: border-color 0.3s;
      }

      .theme-toggle:hover {
        border-color: var(--text);
      }

      .sun { display: none; }
      .moon { display: block; }

      [data-theme="dark"] .sun { display: block; }
      [data-theme="dark"] .moon { display: none; }
    </style>

    <script>
      const toggle = document.getElementById('themeToggle');
      const html = document.documentElement;
      
      // Check for saved preference or system preference
      const savedTheme = localStorage.getItem('theme');
      const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      
      if (savedTheme) {
        html.setAttribute('data-theme', savedTheme);
      } else if (systemDark) {
        html.setAttribute('data-theme', 'dark');
      }

      toggle.addEventListener('click', () => {
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
